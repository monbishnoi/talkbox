{
  "name": "talkbox",
  "version": "0.1.0",
  "description": "Open-source voice orchestrator that gives any AI agent a natural conversational voice.",
  "type": "module",
  "license": "MIT",
  "author": "Monika Bishnoi",
  "homepage": "https://github.com/monbishnoi/talkbox#readme",
  "repository": {
    "type": "git",
