# Talkbox server
HOST=127.0.0.1
PORT=8090

# Primary path: OpenAI Realtime voice brain
OPENAI_API_KEY=your-openai-api-key
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=ash

# Your backend agent. Generic HTTP is the default adapter.
# Talkbox POSTs JSON to this endpoint:
# { "message": "...", "text": "...", "contextId": "...", "metadata": {} }
AGENT_ADAPTER=http
AGENT_ENDPOINT=http://localhost:8080/chat
AGENT_NAME=MyAgent
AGENT_CONTEXT_ID=talkbox
AGENT_TIMEOUT_MS=120000

# Optional: load a markdown persona/identity file into the voice layer.
# Keep this file local and do not commit private agent memory.
# AGENT_VOICE_PERSONA_PATH=./agent-persona.example.md
AGENT_VOICE_PERSONA_MAX_CHARS=4500

# Optional: require clients to send Authorization: Bearer <token>.
# TALKBOX_API_KEY=local-shared-secret

# Test 3 baseline: Deepgram STT + local Piper TTS
# DEEPGRAM_API_KEY=your-deepgram-key
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
STT_PROVIDER=transcript
TTS_PROVIDER=silent
VOICE_MODE=detailed

# Piper HTTP server. Run `npm run install:piper-lessac`, then `npm run piper:start`.
PIPER_HTTP_ENDPOINT=http://127.0.0.1:8092
# PIPER_VOICE=en_US-lessac-medium
# PIPER_LENGTH_SCALE=1

# Local/command adapters
# STT command receives {audio} and may write {output}; stdout is used if no output file exists.
# COMMAND_STT_COMMAND=sherpa-onnx-offline --tokens=... --encoder=... --decoder=... --joiner=... {audio}
SHERPA_TAIL_PADDING_SECONDS=0.8

# TTS command receives {text} and {output}.
# COMMAND_TTS_COMMAND=say -o {output} {text}
COMMAND_TTS_CONTENT_TYPE=audio/aiff
COMMAND_TTS_OUTPUT_NAME=speech.aiff
COMMAND_TIMEOUT_MS=120000

# Experimental/Test 1: Hume EVI bridge
# DEV-ONLY: /hume-token mints short-lived browser access tokens from these local credentials.
# Do not deploy this pattern publicly without adding authentication and origin checks.
# HUME_API_KEY=your-hume-api-key
# HUME_SECRET_KEY=your-hume-secret-key
# HUME_CONFIG_ID=your-evi-config-id
EMOTION_THRESHOLD=0.5

# Reference adapter: Cal Gateway.
# Cal is not required. Use this only if your backend agent is Cal Gateway.
# This is an example deployment, not the default Talkbox setup.
# AGENT_ADAPTER=cal
# AGENT_ENDPOINT=http://localhost:8080
# AGENT_NAME=Cal
